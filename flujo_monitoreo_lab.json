    {
        "id": "ui_css",
        "type": "ui-template",
        "z": "tab_energia_final",
        "group": "g_head",
        "name": "CSS y Reloj",
        "order": 1,
        "width": "12",
        "height": "2",
        "format": "<style>\n    body { background: radial-gradient(circle at 50% 0%, #0a192f 0%, #020c1b 100%) !important; }\n    .nr-dashboard-group { \n        background: rgba(2, 12, 27, 0.8) !important; \n        border: 1px solid #00d2ff !important; \n        box-shadow: 0 0 15px rgba(0,210,255,0.1) !important;\n    }\n    .nr-dashboard-cardtitle { color: #00d2ff !important; font-family: 'Consolas', monospace; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px dashed rgba(0,210,255,0.4); }\n    .nr-dashboard-gauge svg path { filter: drop-shadow(0 0 6px currentColor); }\n    .nr-dashboard-gauge .value { text-shadow: 0 0 10px currentColor; font-weight: 900; font-family: 'Consolas', monospace; }\n    .head-wrap { display: flex; justify-content: space-between; align-items: center; padding: 0 15px; color:#fff; font-family: 'Consolas', monospace; }\n    .head-reloj { font-size: 2.8em; font-weight: bold; color: #00d2ff; text-shadow: 0 0 15px #00d2ff; }\n    .head-text { text-align: right; color: #8892b0; }\n</style>\n\n<div class=\"head-wrap\">\n    <div class=\"head-reloj\" id=\"reloj_utmach\">00:00:00</div>\n    <div class=\"head-text\">\n        <div id=\"fecha_utmach\" style=\"font-size:1.2em; color:#ccd6f6;\">Fecha</div>\n        <div><i class=\"fa fa-bolt\"></i> Facultad Ingeniería Civil - Tecnologías de la Información</div>\n    </div>\n</div>\n\n<script>\n    setInterval(() => {\n        const d = new Date();\n        document.getElementById('reloj_utmach').innerText = d.toLocaleTimeString('es-EC', { hour: '2-digit', minute: '2-digit', second: '2-digit' });\n        document.getElementById('fecha_utmach').innerText = d.toLocaleDateString('es-EC', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });\n    }, 1000);\n</script>",
        "storeOutMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 170,
        "y": 60,
        "wires": [
            []

        "format": "<div style=\"display:flex; gap:20px; font-family:'Consolas', monospace; height:100%;\">\n    \n    <div style=\"flex:1; background:rgba(0,0,0,0.5); border:1px solid rgba(255,255,255,0.1); border-radius:8px; padding:15px;\">\n        <h3 style=\"color:#00d2ff; margin-top:0; border-bottom:1px solid #00d2ff; padding-bottom:5px;\"><i class=\"fa fa-warning\"></i> DIAGNÓSTICO LED</h3>\n        \n        <div style=\"display:flex; justify-content:space-between; align-items:center; margin-top:20px;\">\n            <span style=\"color:#ccd6f6; font-size:1.1em;\">Estado Voltaje:</span>\n            <div style=\"display:flex; align-items:center; gap:10px;\">\n                <span style=\"color: {{msg.payload.alerta_v ? '#ff003c' : '#00ff88'}}; font-weight:bold; text-shadow:0 0 8px currentColor;\">\n                    {{msg.payload.alerta_v ? 'ANORMAL' : 'ESTABLE'}}\n                </span>\n                <div style=\"width:18px; height:18px; border-radius:50%; background-color: {{msg.payload.alerta_v ? '#ff003c' : '#00ff88'}}; box-shadow: 0 0 15px {{msg.payload.alerta_v ? '#ff003c' : '#00ff88'}};\"></div>\n            </div>\n        </div>\n\n        <div style=\"display:flex; justify-content:space-between; align-items:center; margin-top:20px;\">\n            <span style=\"color:#ccd6f6; font-size:1.1em;\">Sobrecarga Potencia:</span>\n            <div style=\"display:flex; align-items:center; gap:10px;\">\n                <span style=\"color: {{msg.payload.alerta_p ? '#ff003c' : '#00ff88'}}; font-weight:bold; text-shadow:0 0 8px currentColor;\">\n                    {{msg.payload.alerta_p ? 'PELIGRO' : 'ÓPTIMO'}}\n                </span>\n                <div style=\"width:18px; height:18px; border-radius:50%; background-color: {{msg.payload.alerta_p ? '#ff003c' : '#00ff88'}}; box-shadow: 0 0 15px {{msg.payload.alerta_p ? '#ff003c' : '#00ff88'}};\"></div>\n            </div>\n        </div>\n    </div>\n\n    \n    <div style=\"flex:1; background:rgba(0,0,0,0.5); border:1px solid rgba(255,255,255,0.1); border-radius:8px; padding:15px;\">\n        <h3 style=\"color:#00ff88; margin-top:0; border-bottom:1px solid #00ff88; padding-bottom:5px;\"><i class=\"fa fa-battery-three-quarters\"></i> PROYECCIÓN kWh</h3>\n        \n        <div style=\"margin-top:10px;\">\n            <div style=\"display:flex; justify-content:space-between; color:#ccd6f6;\"><span>1 Hora:</span> <strong style=\"color:#00d2ff;\">{{msg.payload.cons_h}} kWh</strong></div>\n            <div style=\"width:100%; height:6px; background:#112233; margin-top:5px; border-radius:3px; overflow:hidden;\">\n                <div style=\"width:{{msg.payload.cons_h * 10}}%; height:100%; background:#00d2ff; box-shadow:0 0 8px #00d2ff; transition:width 0.5s;\"></div>\n            </div>\n        </div>\n\n        <div style=\"margin-top:15px;\">\n            <div style=\"display:flex; justify-content:space-between; color:#ccd6f6;\"><span>24 Horas:</span> <strong style=\"color:#00ff88;\">{{msg.payload.cons_d}} kWh</strong></div>\n            <div style=\"width:100%; height:6px; background:#112233; margin-top:5px; border-radius:3px; overflow:hidden;\">\n                <div style=\"width:{{msg.payload.cons_d * 2}}%; height:100%; background:#00ff88; box-shadow:0 0 8px #00ff88; transition:width 0.5s;\"></div>\n            </div>\n        </div>\n\n        <div style=\"margin-top:15px;\">\n            <div style=\"display:flex; justify-content:space-between; color:#ccd6f6;\"><span>7 Días:</span> <strong style=\"color:#ffc800;\">{{msg.payload.cons_w}} kWh</strong></div>\n            <div style=\"width:100%; height:6px; background:#112233; margin-top:5px; border-radius:3px; overflow:hidden;\">\n                <div style=\"width:{{msg.payload.cons_w * 0.5}}%; height:100%; background:#ffc800; box-shadow:0 0 8px #ffc800; transition:width 0.5s;\"></div>\n            </div>\n        </div>\n    </div>\n</div>",
        "storeOutMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",

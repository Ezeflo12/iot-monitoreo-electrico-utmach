    {
        "id": "ch_simulacion",
        "type": "change",
        "z": "tab_energia_final",
        "name": "Simulación Eléctrica",
        "rules": [
            {
                "t": "set",
                "p": "payload",
                "pt": "msg",
                "to": "(\t    $lab := $exists($flowContext(\"lab_select\")) ? $flowContext(\"lab_select\") : 1;\t    $apagado := $flowContext(\"corte_emergencia\") = true ? true : false;\t    \t    $v := $apagado ? 0 : $round($random() * 8 + 116, 1);\t    $i_base := $apagado ? 0 : ($lab = 1 ? 8 : ($lab = 2 ? 22 : 15));\t    $i := $apagado ? 0 : $round($random() * 5 + $i_base, 2);\t    $p := $round($v * $i, 2);\t    $kwh_s := $p / 3600000;\t    \t    {\t        \"voltaje\": $v,\t        \"corriente\": $i,\t        \"potencia\": $p,\t        \"kwh_s\": $kwh_s,\t        \"alerta_v\": $v > 0 and ($v < 118 or $v > 123),\t        \"alerta_p\": $p > ($i_base * 125)\t    }\t)",
                "tot": "jsonata"
            }
        ],
        "action": "",
        "property": "",
        "from": "",
        "to": "",
        "reg": false,
        "x": 350,
        "y": 260,
        "wires": [
            [
                "ch_acumular"
            ]
        ]
    },
    {
        "id": "ch_acumular",
        "type": "change",
        "z": "tab_energia_final",
        "name": "Acumulador kWh Seguro",
        "rules": [
            {
                "t": "set",
                "p": "kwh_total",
                "pt": "flow",
                "to": "$exists($flowContext(\"kwh_total\")) ? $flowContext(\"kwh_total\") + payload.kwh_s : payload.kwh_s",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "payload.cons_h",
                "pt": "msg",
                "to": "$round($flowContext(\"kwh_total\"), 4)",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "payload.cons_d",
                "pt": "msg",
                "to": "$round($flowContext(\"kwh_total\") * 24, 2)",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "payload.cons_w",
                "pt": "msg",
                "to": "$round($flowContext(\"kwh_total\") * 24 * 7, 2)",
                "tot": "jsonata"
            }
        ],
        "action": "",
        "property": "",
        "from": "",
        "to": "",
        "reg": false,
        "x": 570,
        "y": 260,
        "wires": [
            [
                "mqtt_out"
            ]
        ]
    },
